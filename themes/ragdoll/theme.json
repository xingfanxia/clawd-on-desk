{
  "schemaVersion": 1,
  "name": "胖猫",
  "author": "user (custom from real cat)",
  "version": "1.0.0",
  "description": "胖猫 — 海豹色重点双色布偶，毛茸茸大尾巴，天蓝色眼睛 (Ragdoll, seal-point bicolor, blue eyes)",
  "viewBox": {
    "x": 0,
    "y": 0,
    "width": 266,
    "height": 200
