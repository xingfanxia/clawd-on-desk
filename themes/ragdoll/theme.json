  "hitBoxes": {
    "default": {
      "x": 80,
      "y": 30,
      "w": 106,
      "h": 140
    },
    "sleeping": {
      "x": 60,
      "y": 60,
      "w": 146,
      "h": 100
    }
  },
  "sleepingHitboxFiles": [
    "ragdoll-sleeping.apng",
    "ragdoll-collapse-sleep.apng"
  ],
  "reactions": {
    "clickLeft": {
      "file": "ragdoll-react-poke.apng",
