    "collapsing": ["ragdoll-collapse-sleep.apng"],
    "thinking": ["ragdoll-thinking.apng"],
    "working": ["ragdoll-working-typing.apng"],
    "error": ["ragdoll-error.apng"],
    "attention": ["ragdoll-happy.apng"],
    "notification": ["ragdoll-notification.apng"],
    "sleeping": ["ragdoll-sleeping.apng"],
    "waking": ["ragdoll-wake.apng"]
  },
  "idleVariants": {
    "happy":  ["ragdoll-happy.apng"],
    "dozing": ["ragdoll-idle-dozing.apng"]
